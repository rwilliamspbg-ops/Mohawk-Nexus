{
  "name": "Mohawk Nexus Dev Container",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "containerEnv": {
    "GOROOT": "/home/vscode/.go/go1.26.1",
    "PATH": "/home/vscode/.go/go1.26.1/bin:${containerEnv:PATH}"
  },
  "features": {
    "ghcr.io/devcontainers/features/go": {
      "version": "1.26.1"
    },
    "ghcr.io/devcontainers/features/python": {
      "version": "3"
    }
  },
  "postCreateCommand": "echo 'Dev container configured to use Go 1.26.1 and Python 3' && go version || true"
}
