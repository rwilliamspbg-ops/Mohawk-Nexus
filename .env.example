# Example environment variables for local development. Do NOT commit secrets.
# Copy this to `.env` and edit values (or inject via CI / Vault in production).

# Grafana admin password (production: inject from secret manager)
GF_SECURITY_ADMIN_PASSWORD=changeme

# GitHub Container Registry credentials (if pushing images in CI)
#GHCR_USERNAME=your-username
#GHCR_TOKEN=ghp_...
